                            <path d="M122.951 122.489H0c0 30.653 24.85 55.502 55.502 55.502h22.72v21.868c.02 30.597 24.798 55.408 55.39 55.502V133.156c0-5.891-4.776-10.667-10.661-10.667z" fill="#2684FF"/>
                        </svg>
                        <span>Atlassian JIRA</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Security Section -->
    <section class="section security-section" id="security">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Enterprise-Grade Security & Control</h2>
                <p class="section-subtitle">Your data stays yours. Period.</p>
            </div>
            <div class="security-grid">
                <div class="security-card">
                    <span class="security-icon">🔐</span>
                    <h4>SHA-256 Protected</h4>
                    <p>Access codes are hashed using SHA-256 before storage — never stored in plain text</p>
                </div>
                <div class="security-card">
                    <span class="security-icon">💻</span>
                    <h4>Local-Only Storage</h4>
                    <p>Your PAT, API keys, and bug data are stored exclusively in browser localStorage</p>
                </div>
                <div class="security-card">
                    <span class="security-icon">🔒</span>
                    <h4>Zero Server Calls</h4>
                    <p>BugWizard never sends your credentials to any server — all API calls go directly to ADO/JIRA</p>
                </div>
                <div class="security-card">
                    <span class="security-icon">🛡️</span>
                    <h4>No Cloud Storage</h4>
                    <p>No database, no backend, no third-party storage — your bugs stay with you</p>
                </div>
                <div class="security-card">
                    <span class="security-icon">✅</span>
                    <h4>GDPR Compliant</h4>
                    <p>Cookie consent included. Easy data export & deletion anytime</p>
                </div>
            </div>
            <div class="security-detail">
                <h4>How Authentication Works</h4>
                <p>When you enter your Azure DevOps PAT or JIRA API token, it's stored only in your browser's localStorage. API calls are made directly from your browser to Microsoft/Atlassian servers using HTTPS. BugWizard acts purely as a client-side interface — no middleware, no proxies, no data interception.</p>
            </div>
            <div class="security-note">
                <span class="note-highlight">Your data never leaves your browser.</span>
                <a href="../USER_GUIDE_MANUAL.html" class="security-link">Read the User Guide →</a>
            </div>
        </div>
    </section>

